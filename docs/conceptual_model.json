{
  "version": "1.0.0",
  "project": {
    "name": "쟈근친구들 V2 (Conture)",
    "description": "작가가 스토리 초안(콘티)을 올리면, 팬들이 창작에 참여하고 기여를 크레딧으로 인정받는 참여형 플랫폼"
  },
  "entities": [
    {
      "name": "User",
      "description": "플랫폼을 사용하는 모든 사용자 (독자, 작가, 관리자)",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "사용자 고유 식별자" },
        { "name": "email", "type": "String", "required": true, "description": "이메일 주소 (로그인 ID)" },
        { "name": "password", "type": "String", "required": false, "description": "암호화된 비밀번호 (소셜 로그인 시 null)" },
        { "name": "nickname", "type": "String", "required": true, "description": "닉네임 (크레딧 표기용, Unique)" },
        { "name": "role", "type": "Enum", "required": true, "description": "사용자 역할", "enumValues": ["READER", "CREATOR", "ADMIN"] },
        { "name": "authProvider", "type": "Enum", "required": true, "description": "인증 방식", "enumValues": ["EMAIL", "KAKAO", "GOOGLE"] },
        { "name": "status", "type": "Enum", "required": true, "description": "계정 상태", "enumValues": ["ACTIVE", "SUSPENDED", "DELETED"] },
        { "name": "isVerified", "type": "Boolean", "required": true, "description": "본인인증 완료 여부" },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "가입일시" },
        { "name": "updatedAt", "type": "DateTime", "required": true, "description": "정보 수정일시" }
      ],
      "relationships": [
        { "entity": "Wallet", "cardinality": "1:1", "description": "사용자는 하나의 지갑을 보유" },
        { "entity": "Story", "cardinality": "1:N", "description": "작가는 여러 작품을 소유" },
        { "entity": "Proposal", "cardinality": "1:N", "description": "독자는 여러 제안을 생성" },
        { "entity": "Backing", "cardinality": "1:N", "description": "독자는 여러 지지/후원을 수행" },
        { "entity": "WithdrawalRequest", "cardinality": "1:N", "description": "작가는 여러 출금 요청을 생성" }
      ],
      "userStories": ["US-001", "US-002", "US-022", "US-023"]
    },
    {
      "name": "Wallet",
      "description": "사용자의 Ink 재화를 관리하는 지갑",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "지갑 고유 식별자" },
        { "name": "userId", "type": "UUID", "required": true, "description": "소유자 사용자 ID" },
        { "name": "currentBalance", "type": "Integer", "required": true, "description": "현재 Ink 잔액 (정수)" },
        { "name": "payableBalance", "type": "Integer", "required": true, "description": "정산 예정금 (작가용)" },
        { "name": "withdrawableBalance", "type": "Integer", "required": true, "description": "출금 가능 금액 (작가용)" },
        { "name": "updatedAt", "type": "DateTime", "required": true, "description": "잔액 갱신일시" }
      ],
      "relationships": [
        { "entity": "User", "cardinality": "N:1", "description": "지갑은 하나의 사용자에 속함" },
        { "entity": "Transaction", "cardinality": "1:N", "description": "지갑은 여러 트랜잭션 내역을 보유" }
      ],
      "userStories": ["US-003", "US-004", "US-020"]
    },
    {
      "name": "Transaction",
      "description": "Ink 재화의 모든 흐름을 기록하는 불변 로그",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "트랜잭션 고유 식별자" },
        { "name": "walletId", "type": "UUID", "required": true, "description": "관련 지갑 ID" },
        { "name": "type", "type": "Enum", "required": true, "description": "트랜잭션 유형", "enumValues": ["CHARGE", "USE_PROPOSAL", "USE_BACKING", "USE_DIRECT", "REFUND", "SETTLEMENT", "WITHDRAWAL"] },
        { "name": "amount", "type": "Integer", "required": true, "description": "금액 (양수)" },
        { "name": "direction", "type": "Enum", "required": true, "description": "입출금 방향", "enumValues": ["IN", "OUT"] },
        { "name": "referenceType", "type": "Enum", "required": false, "description": "참조 엔티티 유형", "enumValues": ["PAYMENT", "PROPOSAL", "BACKING", "EPISODE", "WITHDRAWAL_REQUEST"] },
        { "name": "referenceId", "type": "UUID", "required": false, "description": "참조 엔티티 ID" },
        { "name": "description", "type": "String", "required": false, "description": "트랜잭션 설명" },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "발생일시" }
      ],
      "relationships": [
        { "entity": "Wallet", "cardinality": "N:1", "description": "트랜잭션은 하나의 지갑에 속함" }
      ],
      "userStories": ["US-004"]
    },
    {
      "name": "Payment",
      "description": "실제 화폐로 Ink를 구매한 결제 내역",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "결제 고유 식별자" },
        { "name": "userId", "type": "UUID", "required": true, "description": "결제자 ID" },
        { "name": "inkAmount", "type": "Integer", "required": true, "description": "충전된 Ink 양" },
        { "name": "paymentAmount", "type": "Integer", "required": true, "description": "결제 금액 (원)" },
        { "name": "paymentMethod", "type": "Enum", "required": true, "description": "결제 수단", "enumValues": ["CARD", "KAKAO_PAY", "TOSS", "PAYPLE"] },
        { "name": "pgTransactionId", "type": "String", "required": true, "description": "PG사 거래 ID" },
        { "name": "status", "type": "Enum", "required": true, "description": "결제 상태", "enumValues": ["PENDING", "COMPLETED", "FAILED", "CANCELLED"] },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "결제 요청일시" },
        { "name": "completedAt", "type": "DateTime", "required": false, "description": "결제 완료일시" }
      ],
      "relationships": [
        { "entity": "User", "cardinality": "N:1", "description": "결제는 하나의 사용자가 수행" }
      ],
      "userStories": ["US-005", "US-027"]
    },
    {
      "name": "Story",
      "description": "작가가 연재하는 작품 (웹툰/웹소설)",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "작품 고유 식별자" },
        { "name": "creatorId", "type": "UUID", "required": true, "description": "작가 ID" },
        { "name": "title", "type": "String", "required": true, "description": "작품 제목" },
        { "name": "description", "type": "String", "required": false, "description": "작품 소개" },
        { "name": "thumbnailUrl", "type": "String", "required": false, "description": "썸네일 이미지 URL" },
        { "name": "totalBounty", "type": "Integer", "required": true, "description": "전체 에피소드 총 모금액" },
        { "name": "status", "type": "Enum", "required": true, "description": "작품 상태", "enumValues": ["DRAFT", "ACTIVE", "HIDDEN", "DELETED"] },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "생성일시" },
        { "name": "updatedAt", "type": "DateTime", "required": true, "description": "수정일시" }
      ],
      "relationships": [
        { "entity": "User", "cardinality": "N:1", "description": "작품은 하나의 작가에 속함" },
        { "entity": "Episode", "cardinality": "1:N", "description": "작품은 여러 에피소드를 포함" }
      ],
      "userStories": ["US-006", "US-007", "US-024"]
    },
    {
      "name": "Episode",
      "description": "작품의 개별 회차 (콘티 또는 완성본)",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "에피소드 고유 식별자" },
        { "name": "storyId", "type": "UUID", "required": true, "description": "소속 작품 ID" },
        { "name": "episodeNumber", "type": "Integer", "required": true, "description": "회차 번호" },
        { "name": "title", "type": "String", "required": true, "description": "에피소드 제목" },
        { "name": "status", "type": "Enum", "required": true, "description": "에피소드 상태", "enumValues": ["DRAFT", "OPEN", "PUBLISHED", "HIDDEN", "DELETED"] },
        { "name": "totalBounty", "type": "Integer", "required": true, "description": "해당 회차 총 모금액" },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "생성일시" },
        { "name": "publishedAt", "type": "DateTime", "required": false, "description": "공개일시" }
      ],
      "relationships": [
        { "entity": "Story", "cardinality": "N:1", "description": "에피소드는 하나의 작품에 속함" },
        { "entity": "EpisodeContent", "cardinality": "1:N", "description": "에피소드는 여러 콘텐츠(이미지/텍스트)를 포함" },
        { "entity": "Proposal", "cardinality": "1:N", "description": "에피소드는 여러 제안을 받음" },
        { "entity": "Backing", "cardinality": "1:N", "description": "에피소드는 여러 직접 후원을 받음" },
        { "entity": "Credit", "cardinality": "1:1", "description": "에피소드는 하나의 크레딧 데이터를 보유" }
      ],
      "userStories": ["US-008", "US-012", "US-014", "US-015", "US-019"]
    },
    {
      "name": "EpisodeContent",
      "description": "에피소드를 구성하는 개별 콘텐츠 (이미지/텍스트)",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "콘텐츠 고유 식별자" },
        { "name": "episodeId", "type": "UUID", "required": true, "description": "소속 에피소드 ID" },
        { "name": "contentType", "type": "Enum", "required": true, "description": "콘텐츠 유형", "enumValues": ["IMAGE", "TEXT"] },
        { "name": "contentUrl", "type": "String", "required": false, "description": "이미지 URL (IMAGE 유형)" },
        { "name": "textContent", "type": "String", "required": false, "description": "텍스트 내용 (TEXT 유형)" },
        { "name": "orderIndex", "type": "Integer", "required": true, "description": "표시 순서" },
        { "name": "isFinal", "type": "Boolean", "required": true, "description": "최종 원고 여부 (true: 완성본)" },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "업로드일시" }
      ],
      "relationships": [
        { "entity": "Episode", "cardinality": "N:1", "description": "콘텐츠는 하나의 에피소드에 속함" }
      ],
      "userStories": ["US-008", "US-014", "US-019"]
    },
    {
      "name": "Proposal",
      "description": "독자가 스토리 전개에 개입하기 위해 생성한 제안",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "제안 고유 식별자" },
        { "name": "episodeId", "type": "UUID", "required": true, "description": "대상 에피소드 ID" },
        { "name": "proposerId", "type": "UUID", "required": true, "description": "제안자 (독자) ID" },
        { "name": "description", "type": "String", "required": true, "description": "제안 내용" },
        { "name": "seedMoney", "type": "Integer", "required": true, "description": "최초 베팅액" },
        { "name": "totalBounty", "type": "Integer", "required": true, "description": "총 모금액 (seedMoney + backing 합계)" },
        { "name": "backerCount", "type": "Integer", "required": true, "description": "지지자 수" },
        { "name": "status", "type": "Enum", "required": true, "description": "제안 상태", "enumValues": ["PENDING", "DEAL", "DROP"] },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "생성일시" },
        { "name": "decidedAt", "type": "DateTime", "required": false, "description": "Deal/Drop 결정일시" }
      ],
      "relationships": [
        { "entity": "Episode", "cardinality": "N:1", "description": "제안은 하나의 에피소드에 속함" },
        { "entity": "User", "cardinality": "N:1", "description": "제안은 하나의 독자가 생성" },
        { "entity": "Backing", "cardinality": "1:N", "description": "제안은 여러 지지를 받음" }
      ],
      "userStories": ["US-009", "US-013", "US-016", "US-017", "US-018"]
    },
    {
      "name": "Backing",
      "description": "독자가 제안에 지지하거나 직접 후원한 기록",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "지지/후원 고유 식별자" },
        { "name": "backerId", "type": "UUID", "required": true, "description": "지지자/후원자 (독자) ID" },
        { "name": "type", "type": "Enum", "required": true, "description": "유형", "enumValues": ["PROPOSAL_BACKING", "DIRECT_BACKING"] },
        { "name": "proposalId", "type": "UUID", "required": false, "description": "지지 대상 제안 ID (PROPOSAL_BACKING)" },
        { "name": "episodeId", "type": "UUID", "required": false, "description": "직접 후원 대상 에피소드 ID (DIRECT_BACKING)" },
        { "name": "amount", "type": "Integer", "required": true, "description": "지지/후원 금액" },
        { "name": "status", "type": "Enum", "required": true, "description": "상태", "enumValues": ["ESCROWED", "SETTLED", "REFUNDED"] },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "생성일시" }
      ],
      "relationships": [
        { "entity": "User", "cardinality": "N:1", "description": "지지/후원은 하나의 독자가 수행" },
        { "entity": "Proposal", "cardinality": "N:1", "description": "지지는 하나의 제안에 속함 (PROPOSAL_BACKING)" },
        { "entity": "Episode", "cardinality": "N:1", "description": "직접 후원은 하나의 에피소드에 속함 (DIRECT_BACKING)" }
      ],
      "userStories": ["US-010", "US-011"]
    },
    {
      "name": "Credit",
      "description": "완성된 에피소드 하단에 표시되는 기여자 크레딧 데이터",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "크레딧 고유 식별자" },
        { "name": "episodeId", "type": "UUID", "required": true, "description": "소속 에피소드 ID" },
        { "name": "contributors", "type": "JSON", "required": true, "description": "기여자 리스트 (nickname, amount, isProposer, rank)" },
        { "name": "mainProducers", "type": "Array[UUID]", "required": true, "description": "상위 3인 Main Producer 사용자 ID 목록" },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "생성일시 (영구 박제)" }
      ],
      "relationships": [
        { "entity": "Episode", "cardinality": "N:1", "description": "크레딧은 하나의 에피소드에 속함" }
      ],
      "userStories": ["US-012", "US-019"]
    },
    {
      "name": "Escrow",
      "description": "제안/지지 시 시스템이 보관하는 에스크로 계정",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "에스크로 고유 식별자" },
        { "name": "proposalId", "type": "UUID", "required": true, "description": "관련 제안 ID" },
        { "name": "totalAmount", "type": "Integer", "required": true, "description": "보관 중인 총 금액" },
        { "name": "status", "type": "Enum", "required": true, "description": "에스크로 상태", "enumValues": ["HOLDING", "RELEASED", "REFUNDED"] },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "생성일시" },
        { "name": "resolvedAt", "type": "DateTime", "required": false, "description": "해제/환불 처리일시" }
      ],
      "relationships": [
        { "entity": "Proposal", "cardinality": "N:1", "description": "에스크로는 하나의 제안에 연결" }
      ],
      "userStories": ["US-009", "US-010", "US-017", "US-018"]
    },
    {
      "name": "WithdrawalRequest",
      "description": "작가가 출금 가능 금액을 실제 계좌로 출금 요청한 내역",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "출금 요청 고유 식별자" },
        { "name": "creatorId", "type": "UUID", "required": true, "description": "요청자 (작가) ID" },
        { "name": "amount", "type": "Integer", "required": true, "description": "출금 요청 금액" },
        { "name": "bankName", "type": "String", "required": true, "description": "은행명" },
        { "name": "accountNumber", "type": "String", "required": true, "description": "계좌번호" },
        { "name": "accountHolder", "type": "String", "required": true, "description": "예금주명" },
        { "name": "status", "type": "Enum", "required": true, "description": "요청 상태", "enumValues": ["PENDING", "APPROVED", "REJECTED", "COMPLETED"] },
        { "name": "adminNote", "type": "String", "required": false, "description": "관리자 메모" },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "요청일시" },
        { "name": "processedAt", "type": "DateTime", "required": false, "description": "처리 완료일시" }
      ],
      "relationships": [
        { "entity": "User", "cardinality": "N:1", "description": "출금 요청은 하나의 작가가 생성" }
      ],
      "userStories": ["US-021", "US-025", "US-026"]
    },
    {
      "name": "Sanction",
      "description": "관리자가 악성 유저에게 부과한 제재 기록",
      "attributes": [
        { "name": "id", "type": "UUID", "required": true, "description": "제재 고유 식별자" },
        { "name": "userId", "type": "UUID", "required": true, "description": "제재 대상 사용자 ID" },
        { "name": "adminId", "type": "UUID", "required": true, "description": "제재 처리 관리자 ID" },
        { "name": "reason", "type": "String", "required": true, "description": "제재 사유" },
        { "name": "type", "type": "Enum", "required": true, "description": "제재 유형", "enumValues": ["WARNING", "SUSPENSION", "PERMANENT_BAN"] },
        { "name": "startAt", "type": "DateTime", "required": true, "description": "제재 시작일시" },
        { "name": "endAt", "type": "DateTime", "required": false, "description": "제재 종료일시 (PERMANENT_BAN은 null)" },
        { "name": "createdAt", "type": "DateTime", "required": true, "description": "생성일시" }
      ],
      "relationships": [
        { "entity": "User", "cardinality": "N:1", "description": "제재는 하나의 사용자에 적용" }
      ],
      "userStories": ["US-023"]
    }
  ],
  "domainRules": [
    {
      "id": "DR-001",
      "name": "닉네임 고유성",
      "description": "닉네임은 플랫폼 전체에서 중복될 수 없음 (크레딧 표기용)",
      "entities": ["User"],
      "constraint": "User.nickname UNIQUE"
    },
    {
      "id": "DR-002",
      "name": "최소 제안 금액",
      "description": "제안 생성 시 최소 100 Ink 이상 베팅해야 함",
      "entities": ["Proposal"],
      "constraint": "Proposal.seedMoney >= 100"
    },
    {
      "id": "DR-003",
      "name": "잔액 초과 사용 불가",
      "description": "제안/지지/후원 시 보유 Ink보다 많은 금액 사용 불가",
      "entities": ["Wallet", "Proposal", "Backing"],
      "constraint": "Transaction.amount <= Wallet.currentBalance"
    },
    {
      "id": "DR-004",
      "name": "에스크로 보관",
      "description": "제안/지지 시 Ink는 시스템 에스크로에 보관되며, Deal 또는 Drop 시까지 유지",
      "entities": ["Proposal", "Backing", "Escrow"],
      "constraint": "Backing.status = ESCROWED until Proposal.status changes"
    },
    {
      "id": "DR-005",
      "name": "Drop 시 전액 환불",
      "description": "제안이 Drop되면 해당 제안의 모든 Backer에게 100% 환불",
      "entities": ["Proposal", "Backing", "Escrow"],
      "constraint": "IF Proposal.status = DROP THEN refund all Backing.amount"
    },
    {
      "id": "DR-006",
      "name": "Deal 시 정산 이관",
      "description": "제안이 Deal되면 에스크로 금액이 작가의 payable_balance로 이동",
      "entities": ["Proposal", "Wallet", "Escrow"],
      "constraint": "IF Proposal.status = DEAL THEN transfer Escrow.totalAmount to Creator.Wallet.payableBalance"
    },
    {
      "id": "DR-007",
      "name": "직접 후원 즉시 정산",
      "description": "직접 후원은 에스크로 없이 즉시 작가의 정산 예정금으로 이동",
      "entities": ["Backing", "Wallet"],
      "constraint": "IF Backing.type = DIRECT_BACKING THEN immediately add to Creator.Wallet.payableBalance"
    },
    {
      "id": "DR-008",
      "name": "최종 원고 업로드 시 정산 전환",
      "description": "완성 원고 업로드 시 payable_balance가 withdrawable_balance로 전환 (수수료 차감)",
      "entities": ["Episode", "Wallet"],
      "constraint": "IF Episode.status changes to PUBLISHED THEN convert payableBalance to withdrawableBalance (minus fee)"
    },
    {
      "id": "DR-009",
      "name": "크레딧 영구 박제",
      "description": "에피소드 공개 시 생성된 크레딧 데이터는 이후 변경 불가",
      "entities": ["Credit", "Episode"],
      "constraint": "Credit is immutable after Episode.status = PUBLISHED"
    },
    {
      "id": "DR-010",
      "name": "크레딧 정렬 규칙",
      "description": "크레딧은 채택된 제안자 우선 표시 후 금액순 정렬, 상위 3인 Main Producer 강조",
      "entities": ["Credit"],
      "constraint": "Sort: Proposer first, then by amount DESC; Top 3 as Main Producer"
    },
    {
      "id": "DR-011",
      "name": "출금 가능 금액 초과 불가",
      "description": "출금 요청 금액은 withdrawable_balance를 초과할 수 없음",
      "entities": ["WithdrawalRequest", "Wallet"],
      "constraint": "WithdrawalRequest.amount <= Wallet.withdrawableBalance"
    },
    {
      "id": "DR-012",
      "name": "OPEN 상태에서만 제안/후원 가능",
      "description": "에피소드 상태가 OPEN일 때만 제안 생성, 지지, 직접 후원 가능",
      "entities": ["Episode", "Proposal", "Backing"],
      "constraint": "Proposal/Backing creation requires Episode.status = OPEN"
    },
    {
      "id": "DR-013",
      "name": "제재된 사용자 로그인 차단",
      "description": "SUSPENDED 또는 PERMANENT_BAN 제재 적용 시 해당 사용자 로그인 차단",
      "entities": ["User", "Sanction"],
      "constraint": "IF User.status = SUSPENDED THEN block login"
    }
  ],
  "dataFlows": [
    {
      "name": "독자 회원가입 및 Ink 충전 플로우",
      "steps": [
        "User 생성 (email/social)",
        "Wallet 자동 생성 (currentBalance = 0)",
        "Payment 생성 (PG 결제)",
        "Transaction 생성 (type: CHARGE)",
        "Wallet.currentBalance 증가"
      ],
      "entities": ["User", "Wallet", "Payment", "Transaction"]
    },
    {
      "name": "제안 생성 플로우",
      "steps": [
        "Episode.status = OPEN 확인",
        "Wallet.currentBalance >= seedMoney 확인",
        "Proposal 생성",
        "Escrow 생성",
        "Backing 생성 (type: PROPOSAL_BACKING, 제안자 본인)",
        "Transaction 생성 (type: USE_PROPOSAL)",
        "Wallet.currentBalance 감소"
      ],
      "entities": ["Episode", "Wallet", "Proposal", "Escrow", "Backing", "Transaction"]
    },
    {
      "name": "제안 지지 플로우",
      "steps": [
        "Proposal.status = PENDING 확인",
        "Wallet.currentBalance >= amount 확인",
        "Backing 생성 (type: PROPOSAL_BACKING)",
        "Escrow.totalAmount 증가",
        "Proposal.totalBounty, backerCount 증가",
        "Transaction 생성 (type: USE_BACKING)",
        "Wallet.currentBalance 감소"
      ],
      "entities": ["Proposal", "Wallet", "Backing", "Escrow", "Transaction"]
    },
    {
      "name": "직접 후원 플로우",
      "steps": [
        "Episode.status = OPEN 확인",
        "Wallet.currentBalance >= amount 확인",
        "Backing 생성 (type: DIRECT_BACKING, status: SETTLED)",
        "Transaction 생성 (type: USE_DIRECT)",
        "독자 Wallet.currentBalance 감소",
        "작가 Wallet.payableBalance 증가"
      ],
      "entities": ["Episode", "Wallet", "Backing", "Transaction"]
    },
    {
      "name": "Deal (채택) 플로우",
      "steps": [
        "Proposal.status → DEAL",
        "Escrow.status → RELEASED",
        "모든 Backing.status → SETTLED",
        "작가 Wallet.payableBalance 증가",
        "Transaction 생성 (type: SETTLEMENT)"
      ],
      "entities": ["Proposal", "Escrow", "Backing", "Wallet", "Transaction"]
    },
    {
      "name": "Drop (거절) 플로우",
      "steps": [
        "Proposal.status → DROP",
        "Escrow.status → REFUNDED",
        "모든 Backing.status → REFUNDED",
        "각 Backer의 Wallet.currentBalance 복구",
        "Transaction 생성 (type: REFUND) per backer"
      ],
      "entities": ["Proposal", "Escrow", "Backing", "Wallet", "Transaction"]
    },
    {
      "name": "완성 원고 공개 플로우",
      "steps": [
        "EpisodeContent 생성 (isFinal: true)",
        "Episode.status → PUBLISHED",
        "Credit 자동 생성 (기여자 집계)",
        "작가 Wallet: payableBalance → withdrawableBalance (수수료 차감)"
      ],
      "entities": ["Episode", "EpisodeContent", "Credit", "Wallet"]
    },
    {
      "name": "출금 요청 플로우",
      "steps": [
        "Wallet.withdrawableBalance >= amount 확인",
        "WithdrawalRequest 생성 (status: PENDING)",
        "관리자 검토",
        "WithdrawalRequest.status → APPROVED/REJECTED",
        "승인 시 실제 이체 후 COMPLETED",
        "Wallet.withdrawableBalance 감소",
        "Transaction 생성 (type: WITHDRAWAL)"
      ],
      "entities": ["Wallet", "WithdrawalRequest", "Transaction"]
    }
  ],
  "glossary": [
    {
      "term": "Ink",
      "definition": "플랫폼 내 유료 재화. 실제 화폐로 구매하며, 제안/지지/후원에 사용"
    },
    {
      "term": "콘티",
      "definition": "작가가 업로드하는 스토리 초안 (이미지/텍스트). OPEN 상태에서 후원/제안을 받음"
    },
    {
      "term": "제안 (Proposal)",
      "definition": "독자가 스토리 전개에 개입하기 위해 Ink를 걸고 생성하는 요청"
    },
    {
      "term": "지지 (Backing)",
      "definition": "다른 독자의 제안에 추가로 Ink를 더해 채택 확률을 높이는 행위"
    },
    {
      "term": "직접 후원 (Direct Backing)",
      "definition": "제안 없이 순수하게 창작을 지원하는 후원 방식"
    },
    {
      "term": "Bounty",
      "definition": "제안에 모인 총 금액 (seedMoney + 모든 backing 금액)"
    },
    {
      "term": "에스크로 (Escrow)",
      "definition": "제안/지지 시 시스템이 Ink를 임시 보관하는 계정. Deal 또는 Drop 시 해제"
    },
    {
      "term": "Deal",
      "definition": "작가가 제안을 채택하는 것. 에스크로 금액이 작가에게 이동"
    },
    {
      "term": "Drop",
      "definition": "작가가 제안을 거절하는 것. 에스크로 금액이 참여자에게 100% 환불"
    },
    {
      "term": "크레딧 (Credit)",
      "definition": "완성된 에피소드 하단에 표시되는 기여자 명단. 영구 박제됨"
    },
    {
      "term": "Main Producer",
      "definition": "기여 금액 상위 3인에게 부여되는 특별 타이틀"
    },
    {
      "term": "payable_balance",
      "definition": "정산 예정금. Deal 또는 직접 후원 시 누적되는 금액"
    },
    {
      "term": "withdrawable_balance",
      "definition": "출금 가능 금액. 완성 원고 공개 후 수수료 차감된 금액"
    },
    {
      "term": "OPEN",
      "definition": "에피소드 상태. 후원 및 제안을 받을 수 있는 상태"
    },
    {
      "term": "PUBLISHED",
      "definition": "에피소드 상태. 완성 원고가 공개된 상태. 제안/후원 불가"
    }
  ]
}
