{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tasks JSON Schema",
  "description": "프론트엔드 개발 Task 관리를 위한 JSON 스키마",
  "type": "object",
  "required": ["meta", "features"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "lastChange", "lastUpdated", "project", "totalTasks"],
      "properties": {
        "version": {
          "type": "string",
          "description": "버전 정보 (예: 2026-01-09.2)",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.\\d+$"
        },
        "lastChange": {
          "type": "string",
          "description": "마지막 변경 ID (예: change-2026-01-09-1137)",
          "pattern": "^change-\\d{4}-\\d{2}-\\d{2}-\\d{4}$"
        },
        "lastUpdated": {
          "type": "string",
          "description": "마지막 업데이트 시간 (ISO 8601)",
          "format": "date-time"
        },
        "project": {
          "type": "string",
          "description": "프로젝트 이름"
        },
        "totalTasks": {
          "type": "integer",
          "description": "전체 Task 개수",
          "minimum": 0
        }
      }
    },
    "features": {
      "type": "array",
      "description": "기능 단위별로 그룹화된 Task 목록",
      "items": {
        "type": "object",
        "required": ["name", "tasks"],
        "properties": {
          "name": {
            "type": "string",
            "description": "기능 이름 (예: 프로젝트 설정, 레이아웃, 인증)"
          },
          "tasks": {
            "type": "array",
            "description": "해당 기능의 Task 목록",
            "items": {
              "type": "object",
              "required": ["id", "title", "status", "priority", "dependencies", "files", "created_at", "updated_at"],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "고유 Task ID (예: task-001)",
                  "pattern": "^task-\\d{3}$"
                },
                "title": {
                  "type": "string",
                  "description": "Task 제목 (한 문장)",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "description": "Task 상태",
                  "enum": ["pending", "in_progress", "completed", "blocked"]
                },
                "priority": {
                  "type": "string",
                  "description": "우선순위",
                  "enum": ["high", "medium", "low"]
                },
                "dependencies": {
                  "type": "array",
                  "description": "의존하는 Task ID 목록",
                  "items": {
                    "type": "string",
                    "pattern": "^task-\\d{3}$"
                  }
                },
                "files": {
                  "type": "array",
                  "description": "관련 파일 경로 목록",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "created_at": {
                  "type": "string",
                  "description": "생성 시간 (ISO 8601)",
                  "format": "date-time"
                },
                "updated_at": {
                  "type": "string",
                  "description": "수정 시간 (ISO 8601)",
                  "format": "date-time"
                },
                "completed_at": {
                  "type": "string",
                  "description": "완료 시간 (ISO 8601, status=completed일 때만)",
                  "format": "date-time"
                },
                "notes": {
                  "type": "string",
                  "description": "Task 관련 메모 또는 추가 정보"
                },
                "blocked_reason": {
                  "type": "string",
                  "description": "blocked 상태일 때 사유"
                }
              }
            }
          }
        }
      }
    }
  }
}
